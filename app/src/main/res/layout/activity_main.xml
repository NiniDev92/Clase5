<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DEC6E8"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/editDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#331C39"
        android:hint="Escribe una dirección web" />

    <CheckBox
        android:id="@+id/checkConfirmar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirmar dirección" />

    <Button
        android:id="@+id/botonAbrir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abrir página"
        app:rippleColor="#B695E4" />

</LinearLayout>